{
  "manifest_version": 3,
  "name": "FullSnap – Full Page Screenshot",
  "version": "1.1.0",
  "description": "Capture a full-page screenshot in one click. Scrolls, stitches, and exports as PNG or PDF.",

  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "unlimitedStorage"
  ],

  "host_permissions": ["<all_urls>"],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "FullSnap – Full Page Screenshot"
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+P",
        "mac":     "Alt+Shift+P"
      },
      "description": "Open FullSnap capture popup"
    }
  },

  "background": {
    "service_worker": "background.js"
  },

  "web_accessible_resources": [
    {
      "resources": ["preview.html", "preview.js", "jspdf.umd.min.js", "icons/*"],
      "matches":   ["<all_urls>"]
    }
  ]
}
